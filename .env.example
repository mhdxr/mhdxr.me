# ==================================
# SITE CONFIGURATION
# ==================================
BUNDLE_ANALYZER=false
SITE_URL=https://mhdxr.me

# Email of the site owner. Used by the guestbook UI to flag the "Author"
# badge and to allow the owner to moderate messages from the client. Must be
# the same email the owner signs in with via next-auth (Google/GitHub).
# Falls back to a sensible default if unset.
NEXT_PUBLIC_OWNER_EMAIL=

# ==================================
# BLOG & CONTENT
# ==================================
# WordPress API URL for blog content
BLOG_API_URL=

# DEV.to API key for fetching articles
DEVTO_KEY=

# ==================================
# AI & CHATBOT
# ==================================
# OpenAI API key for ChatGPT feature (cmd+k)
OPENAI_API_KEY=

# ==================================
# INTEGRATIONS
# ==================================

# Spotify API - For "Now Playing" widget
# Get credentials from: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=

# WakaTime API - For coding statistics
# Get API key from: https://wakatime.com/settings/api-key
WAKATIME_API_KEY=

# GitHub API - For repository data
# Generate tokens from: https://github.com/settings/tokens
GITHUB_READ_USER_TOKEN_PERSONAL=
GITHUB_READ_USER_TOKEN_WORK=

# ==================================
# DATABASE (PostgreSQL via Prisma)
# ==================================
# Main database connection (with connection pooling)
DATABASE_URL='postgres://USER:PASSWORD@HOST:5432/postgres'

# Direct database connection (required for migrations)
# For Vercel/Supabase: use direct connection string
DIRECT_URL='postgres://USER:PASSWORD@HOST:5432/postgres'

# ==================================
# CONTACT FORM
# ==================================
# API key for contact form service
CONTACT_FORM_API_KEY=

# ==================================
# FIREBASE (Realtime Guestbook)
# ==================================
# Get credentials from: https://console.firebase.google.com
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_DB_URL=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
NEXT_PUBLIC_FIREBASE_CHAT_DB=

# ==================================
# AUTHENTICATION (Next-Auth)
# ==================================
# Base URL for authentication callbacks
NEXTAUTH_URL=http://localhost:3000

# Secret used by next-auth to sign JWT/session cookies. REQUIRED in production.
# Generate one with: `openssl rand -base64 32`
NEXTAUTH_SECRET=

# Google OAuth credentials
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth credentials
# Get from: https://github.com/settings/developers
GITHUB_ID=
GITHUB_SECRET=
